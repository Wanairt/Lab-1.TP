@model Lab_1.TP.Models.Calculator

@{
    ViewData["Title"] = "Калькулятор";
}

<h2>Калькулятор (byte и double)</h2>

@Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

@using (Html.BeginForm("Index", "Calculator", FormMethod.Post))
{
    <div>
        @Html.LabelFor(model => model.Operand1Input, "Операнд 1 (byte):")
        <br />
        @Html.TextBoxFor(model => model.Operand1Input, new { @class = "text-box" })
        @Html.ValidationMessageFor(model => model.Operand1Input, "", new { @class = "field-validation-error" })
    </div>

    <div>
        @Html.LabelFor(model => model.Operand2Input, "Операнд 2 (double):")
        <br />
        @Html.TextBoxFor(model => model.Operand2Input, new { @class = "text-box" })
        @Html.ValidationMessageFor(model => model.Operand2Input, "", new { @class = "field-validation-error" })
    </div>

    <div>
        @Html.LabelFor(model => model.Operation, "Операция:")
        <br />
        @Html.ListBoxFor(model => model.Operation,
            new List<SelectListItem>
            {
                new SelectListItem { Text = "Сложение (+)", Value = "+" },
                new SelectListItem { Text = "Вычитание (-)", Value = "-" },
                new SelectListItem { Text = "Умножение (*)", Value = "*" },
                new SelectListItem { Text = "Деление (/)", Value = "/" }
            },
            new { @class = "form-control", size = 4 })
    </div>

    <div>
        <button type="submit" name="button" value="calculate">Вычислить</button>
        <button type="submit" name="button" value="clear">Очистить</button>
    </div>
}

<div>
    <div>
        <strong>Результат:</strong>
        @if (Model != null && !double.IsNaN(Model.Result))
        {
            <span>@Model.Result</span>

            if (Model.Result == ViewBag.ComparisonValue)
            {
                <p style="color: green;">✓ Результат совпадает с заданным значением (@ViewBag.ComparisonValue)!</p>
            }
            else
            {
                <p style="color: blue;">✗ Результат не совпадает с заданным значением (@ViewBag.ComparisonValue).</p>
            }

        }
        else if (Model != null && double.IsNaN(Model.Result))
        {
            <span style="color:red;">Ошибка! Неверный ввод или деление на 0.</span>
        }
        @if (Model != null &&
     !string.IsNullOrEmpty(Model.Operand1Input) &&
     !string.IsNullOrEmpty(Model.Operand2Input) &&
     !string.IsNullOrEmpty(Model.Operation))
        {
            <div style="margin-top: 15px;">
                @Html.ActionLink("Подробнее об операции", "ResultInfo", "Calculator",
                    new
                    {
                        operand1 = Model.Operand1Input,
                        operand2 = Model.Operand2Input,
                        operation = Model.Operation,
                        result = Model.Result
                    },
                    new { @class = "btn-details" })
            </div>
        }
        else if (Model != null && double.IsNaN(Model.Result))
        {
        <span style="color:red;">Ошибка! Неверный ввод или деление на 0.</span>
        }
    </div>
</div>

